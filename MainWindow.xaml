<Window
    x:Class="ImageTagger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:ImageTagger.Models"
    xmlns:conv="clr-namespace:ImageTagger.Converters"
    mc:Ignorable="d"
    Title="ImageTagger"
    Icon="pack://application:,,,/app.ico"
    Height="820" Width="920"
    MinHeight="640" MinWidth="700"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource ApplicationBackgroundBrush}">

    <Window.Resources>
        <conv:NullOrEmptyToCollapsedConverter  x:Key="NullToCollapsed"/>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVisible"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVisible"/>

        <!-- Clean ListViewItem — removes selection highlight chrome -->
        <Style x:Key="CleanListItem" TargetType="ListViewItem">
            <Setter Property="Padding"                    Value="4,2"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         Root grid — rows:  Config | Progress | Log (★) | Undo
    ════════════════════════════════════════════════════════════════════════ -->
    <Grid Margin="12,8,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Config card        -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>   <!-- Progress card      -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>      <!-- Activity log card  -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>   <!-- Undo expander      -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0 – Configuration
        ════════════════════════════════════════════════════════════════════ -->
        <ui:Card Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Configuration"
                           FontSize="15" FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <!-- Source folder -->
                <Grid Margin="0,0,0,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Image folder"
                               VerticalAlignment="Center"/>
                    <ui:TextBox Grid.Column="1" Margin="8,0"
                                Text="{Binding SourceFolder, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Select a folder containing images…"
                                IsEnabled="{Binding IsNotProcessing}"/>
                    <ui:Button Grid.Column="2" Content="Browse"
                               Command="{Binding BrowseFolderCommand}"/>
                </Grid>

                <!-- Ollama URL + status -->
                <Grid Margin="0,0,0,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ollama URL"
                               VerticalAlignment="Center"/>
                    <ui:TextBox Grid.Column="1" Margin="8,0"
                                Text="{Binding OllamaUrl, UpdateSourceTrigger=LostFocus}"/>
                    <ui:Button Grid.Column="2" Content="↺" Margin="0,0,8,0"
                               ToolTip="Refresh Ollama connection"
                               Command="{Binding RefreshOllamaCommand}"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9" Margin="0,0,5,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#CC4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OllamaAvailable}" Value="True">
                                            <Setter Property="Fill" Value="#44CC77"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding OllamaStatus}"
                                   FontSize="12" Opacity="0.65"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Model + Language (side by side) -->
                <Grid Margin="0,0,0,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Model"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Margin="8,0,0,0"
                              ItemsSource="{Binding OllamaModels}"
                              SelectedItem="{Binding SelectedModel}"
                              IsEnabled="{Binding IsNotProcessing}"/>
                    <TextBlock Grid.Column="3" Text="Language"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <ComboBox Grid.Column="4" Margin="8,0,0,0"
                              ItemsSource="{Binding Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              IsEnabled="{Binding IsNotProcessing}"/>
                </Grid>

                <!-- Force options -->
                <StackPanel Orientation="Horizontal" Margin="148,0,0,7">
                    <CheckBox Content="Force re-tag"
                              IsChecked="{Binding ForceTag}"
                              IsEnabled="{Binding IsNotProcessing}"
                              ToolTip="Overwrite EXIF even if already tagged"
                              Margin="0,0,24,0"/>
                    <CheckBox Content="Force rename"
                              IsChecked="{Binding ForceRename}"
                              IsEnabled="{Binding IsNotProcessing}"
                              ToolTip="Rename even if filename is not a camera default"/>
                </StackPanel>

                <!-- Advanced expander -->
                <Expander Header="Advanced options" Margin="0,2,0,0">
                    <Grid Margin="148,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>   <!-- Row 0: Min resolution  -->
                            <RowDefinition Height="30"/>   <!-- Row 1: Ollama timeout  -->
                            <RowDefinition Height="30"/>   <!-- Row 2: Max title words  -->
                            <RowDefinition Height="Auto"/> <!-- Row 3: Cache folder     -->
                            <RowDefinition Height="8"/>    <!-- Row 4: Gap              -->
                            <RowDefinition Height="Auto"/> <!-- Row 5: Discord webhook  -->
                        </Grid.RowDefinitions>

                        <!-- Min resolution -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min resolution (px)"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="0" Grid.Column="1"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:NumberBox Value="{Binding MinWidth}"  Minimum="0" Maximum="99999"
                                          SpinButtonPlacementMode="Compact" Width="90"
                                          Padding="8,0" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" × " VerticalAlignment="Center" Margin="4,0"/>
                            <ui:NumberBox Value="{Binding MinHeight}" Minimum="0" Maximum="99999"
                                          SpinButtonPlacementMode="Compact" Width="90"
                                          Padding="8,0" VerticalContentAlignment="Center"/>
                            <TextBlock Text="  (0 = no filter)" VerticalAlignment="Center"
                                       Opacity="0.5" FontSize="11" Margin="6,0,0,0"/>
                        </StackPanel>

                        <!-- Timeout -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ollama timeout (s)"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Grid.Column="1"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:NumberBox Value="{Binding OllamaTimeoutSec}"
                                          Minimum="10" Maximum="600"
                                          SpinButtonPlacementMode="Compact" Width="90"
                                          Padding="8,0" VerticalContentAlignment="Center"/>
                            <TextBlock Text=" per image" VerticalAlignment="Center"
                                       Opacity="0.5" FontSize="11" Margin="6,0,0,0"/>
                        </StackPanel>

                        <!-- Max title words -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max title words"
                                   VerticalAlignment="Center"/>
                        <ui:NumberBox Grid.Row="2" Grid.Column="1"
                                      Value="{Binding CondensedMaxWords}"
                                      Minimum="2" Maximum="10"
                                      SpinButtonPlacementMode="Compact" Width="90"
                                      VerticalAlignment="Center"
                                      Padding="8,0" VerticalContentAlignment="Center"/>

                        <!-- Cache folder -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Cache folder"
                                   VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <Grid Grid.Row="3" Grid.Column="1" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Margin="0,0,8,0"
                                        Text="{Binding CacheFolder, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Default — Documents\ImageTagger\cache"/>
                            <ui:Button Grid.Column="1" Content="Browse" Margin="0,0,6,0"
                                       Command="{Binding BrowseCacheFolderCommand}"/>
                            <ui:Button Grid.Column="2" Content="Open ↗"
                                       ToolTip="Open cache folder in Explorer"
                                       Command="{Binding OpenCacheFolderCommand}"/>
                        </Grid>

                        <!-- Row 4 is an 8 px gap (RowDefinition Height="8") -->

                        <!-- Discord webhook -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Discord notify"
                                   VerticalAlignment="Center" Margin="0,4,0,4"/>
                        <Grid Grid.Row="5" Grid.Column="1" Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- checkbox        -->
                                <ColumnDefinition Width="*"/>     <!-- URL text box    -->
                                <ColumnDefinition Width="Auto"/>  <!-- Test button     -->
                                <ColumnDefinition Width="Auto"/>  <!-- status dot+text -->
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding DiscordWebhookEnabled}"
                                      VerticalAlignment="Center"
                                      ToolTip="Send a Discord message when processing completes"
                                      Margin="0,0,8,0"/>

                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding DiscordWebhookUrl,
                                            UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="https://discord.com/api/webhooks/…"
                                        IsEnabled="{Binding DiscordWebhookEnabled}"
                                        Margin="0,0,8,0"/>

                            <ui:Button Grid.Column="2"
                                       Content="Test"
                                       IsEnabled="{Binding DiscordWebhookEnabled}"
                                       Command="{Binding ValidateDiscordWebhookCommand}"
                                       ToolTip="Send a GET request to verify the webhook URL"
                                       Margin="0,0,8,0"/>

                            <!-- Status indicator — hidden when status is Unchecked -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Margin="0,0,5,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill"       Value="Gray"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiscordWebhookStatus}"
                                                             Value="{x:Static models:WebhookStatus.Checking}">
                                                    <Setter Property="Fill"       Value="#F0A500"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiscordWebhookStatus}"
                                                             Value="{x:Static models:WebhookStatus.Valid}">
                                                    <Setter Property="Fill"       Value="#44CC77"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiscordWebhookStatus}"
                                                             Value="{x:Static models:WebhookStatus.Invalid}">
                                                    <Setter Property="Fill"       Value="#CC4444"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="12" Opacity="0.65" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DiscordWebhookStatus}"
                                                             Value="{x:Static models:WebhookStatus.Checking}">
                                                    <Setter Property="Text" Value="Checking…"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiscordWebhookStatus}"
                                                             Value="{x:Static models:WebhookStatus.Valid}">
                                                    <Setter Property="Text" Value="Valid"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DiscordWebhookStatus}"
                                                             Value="{x:Static models:WebhookStatus.Invalid}">
                                                    <Setter Property="Text" Value="Invalid URL"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Expander>
            </StackPanel>
        </ui:Card>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2 – Progress + controls
        ════════════════════════════════════════════════════════════════════ -->
        <ui:Card Grid.Row="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Processing"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button Content="▶  Start" Appearance="Primary"
                                   Command="{Binding StartCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="■  Stop"
                                   Command="{Binding StopCommand}"/>
                    </StackPanel>
                </Grid>

                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             Minimum="0" Maximum="100" Height="6">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar"
                               BasedOn="{StaticResource {x:Type ProgressBar}}">
                            <!-- Idle: dim/neutral -->
                            <Setter Property="Foreground" Value="#666666"/>
                            <Style.Triggers>
                                <!-- Processing: amber/yellow -->
                                <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                    <Setter Property="Foreground" Value="#E8A000"/>
                                </DataTrigger>
                                <!-- Complete: green (fires after IsProcessing → False) -->
                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                    <Setter Property="Foreground" Value="#44CC77"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.65" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                               Opacity="0.65" FontSize="12"/>
                </Grid>
            </Grid>
        </ui:Card>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 4 – Activity Log  (★ fills remaining height)
        ════════════════════════════════════════════════════════════════════ -->
        <ui:Card Grid.Row="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Activity Log"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <ui:Button Grid.Column="1" Content="Clear"
                               Appearance="Secondary"
                               Command="{Binding ClearLogCommand}"/>
                </Grid>

                <ListView Grid.Row="2"
                          ItemsSource="{Binding LogEntries}"
                          ItemContainerStyle="{StaticResource CleanListItem}"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          BorderThickness="0" Background="Transparent"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:LogEntry}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Timestamp — read-only TextBox so text is selectable/copyable -->
                                <TextBox Grid.Column="0"
                                         Text="{Binding TimeText, Mode=OneWay}"
                                         IsReadOnly="True" IsTabStop="False"
                                         BorderThickness="0" Padding="0"
                                         Background="Transparent"
                                         FontFamily="Consolas" FontSize="11"
                                         Opacity="0.45" VerticalAlignment="Top"
                                         Cursor="IBeam"/>

                                <StackPanel Grid.Column="1">
                                    <!-- Primary text — read-only TextBox so text is selectable/copyable -->
                                    <TextBox Text="{Binding PrimaryText, Mode=OneWay}"
                                             IsReadOnly="True" IsTabStop="False"
                                             BorderThickness="0" Padding="0"
                                             Background="Transparent"
                                             FontSize="13"
                                             TextWrapping="NoWrap"
                                             Cursor="IBeam">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}"
                                                                 Value="{x:Static models:LogEntryKind.Processed}">
                                                        <Setter Property="Foreground" Value="#5DC97A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}"
                                                                 Value="{x:Static models:LogEntryKind.Failed}">
                                                        <Setter Property="Foreground" Value="#E05C5C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}"
                                                                 Value="{x:Static models:LogEntryKind.Skipped}">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Secondary text — read-only TextBox so text is selectable/copyable -->
                                    <TextBox Text="{Binding SecondaryText, Mode=OneWay}"
                                             IsReadOnly="True" IsTabStop="False"
                                             BorderThickness="0" Padding="0"
                                             Background="Transparent"
                                             FontSize="11" Opacity="0.55"
                                             TextWrapping="Wrap"
                                             Margin="0,1,0,0"
                                             Cursor="IBeam"
                                             Visibility="{Binding SecondaryText,
                                                 Converter={StaticResource NullToCollapsed}}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </ui:Card>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 6 – Undo
        ════════════════════════════════════════════════════════════════════ -->
        <Expander Grid.Row="6" IsExpanded="{Binding UndoPanelExpanded}">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Undo" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Margin="8,0,0,0" Opacity="0.5" FontSize="12"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="({0} entries)">
                                <Binding Path="UndoItems.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Expander.Header>

            <ui:Card Margin="0,4,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <ui:Button Content="Select All"
                                   Appearance="Secondary"
                                   Command="{Binding SelectAllUndoCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Select None"
                                   Appearance="Secondary"
                                   Command="{Binding SelectNoneUndoCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Undo Selected"
                                   Command="{Binding UndoSelectedCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Undo All"
                                   Appearance="Danger"
                                   Command="{Binding UndoAllCommand}"/>
                    </StackPanel>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding UndoItems}"
                              ItemContainerStyle="{StaticResource CleanListItem}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              BorderThickness="0" Background="Transparent"
                              VirtualizingPanel.IsVirtualizing="True">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:UndoItem}">
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                  UpdateSourceTrigger=PropertyChanged}"
                                              Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayText}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" FontSize="13"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StatusBadge}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="13" Opacity="0.6"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </ui:Card>
        </Expander>

    </Grid>
</Window>
